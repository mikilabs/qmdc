.vscode/**
.vscode-test/**
src/**
scripts/**
.gitignore
.yarnrc
vsc-extension-quickstart.md
**/tsconfig.json
**/.eslintrc.json
eslint.config.js
**/*.map
**/*.ts
!**/*.d.ts
*.vsix

# Exclude devDependencies (keep only production deps)
node_modules/@types/**
node_modules/@typescript-eslint/**
node_modules/@vscode/vsce/**
node_modules/@playwright/**
node_modules/eslint/**
node_modules/tsx/**
node_modules/typescript/**

# Exclude test files
e2e/**
playwright.config.ts
test-results/**

# Mermaid: keep only mermaid.min.js, exclude everything else
node_modules/mermaid/dist/*.map
node_modules/mermaid/dist/*.mjs
node_modules/mermaid/dist/*.mjs.map
node_modules/mermaid/dist/mermaid.js
node_modules/mermaid/dist/*.d.ts
node_modules/mermaid/dist/__mocks__/**
node_modules/mermaid/dist/docs/**
node_modules/mermaid/dist/dagre-wrapper/**
node_modules/mermaid/dist/diagram-api/**
node_modules/mermaid/dist/diagrams/**
node_modules/mermaid/dist/chunks/**
node_modules/mermaid/dist/accessibility*
node_modules/mermaid/dist/assignWithDepth*
node_modules/mermaid/dist/config*
node_modules/mermaid/dist/defaultConfig*
node_modules/mermaid/dist/errors*
node_modules/mermaid/dist/interactionDb*
node_modules/mermaid/dist/internals*
node_modules/mermaid/dist/logger*
node_modules/mermaid/dist/mermaidAPI*
node_modules/mermaid/dist/Diagram*
