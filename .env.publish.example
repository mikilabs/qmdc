# .env.publish — registry tokens for `make publish` (real, idempotent release).
#
# Copy this file to `.env.publish` and fill in the values. `.env.publish` is
# gitignored — NEVER commit real tokens. release-publish.sh auto-sources it.
#
#   cp .env.publish.example .env.publish   # then fill in the tokens
#   make publish-check                     # dry-run: build matrix, show what WOULD publish
#   make publish                           # real: build matrix + idempotent upload to all registries
#
# In CI these are NOT read from this file — they come from GitHub Secrets of the
# same names (see .github/workflows/release.yml).

# ── PyPI ──────────────────────────────────────────────────────────────────
# Packages: qmdc, qmdc-semantic, qmdc-mkdocs
# Where: https://pypi.org/manage/account/token/  →  "Add API token"
#   • First publish: use an account-wide token; afterwards you can re-scope it
#     to the "qmdc" project. The token value starts with "pypi-".
UV_PUBLISH_TOKEN=

# ── npm ───────────────────────────────────────────────────────────────────
# Packages: @qmdc/qmdc  +  @qmdc/cli-<platform> (x7)
# Where: https://www.npmjs.com/settings/<your-username>/tokens
#   IMPORTANT: the token MUST be able to publish without an interactive 2FA prompt.
#   Use ONE of:
#     • Classic token → type "Automation"  (bypasses 2FA — simplest), or
#     • Granular Access Token with "Read and write" on the qmdc package + the
#       @qmdc scope, AND "Bypass two-factor authentication" enabled.
#   A plain classic "Publish" token will fail with 403 (2FA required).
NODE_AUTH_TOKEN=

# ── crates.io ─────────────────────────────────────────────────────────────
# Package: qmdc (crate)
# Where: https://crates.io/settings/tokens  →  "New Token"
#   • Scopes: publish-new + publish-update.
CARGO_REGISTRY_TOKEN=

# ── VS Code Marketplace ────────────────────────────────────────────────────
# Package: qmdc-vscode (publisher: mikilabs)
# Where: an Azure DevOps Personal Access Token.
#   https://dev.azure.com  →  User settings (top-right)  →  Personal Access Tokens
#   →  New Token  →  Organization: "All accessible organizations"
#   →  Scopes: "Marketplace" → "Manage".
#   The publisher "mikilabs" must exist: https://marketplace.visualstudio.com/manage
VSCE_PAT=

# ── Open VSX ───────────────────────────────────────────────────────────────
# Package: qmdc-vscode (namespace: mikilabs)
# Where: https://open-vsx.org  →  log in  →  Settings  →  Access Tokens  →  Generate.
#   One-time namespace creation (run once):
#     npx ovsx create-namespace mikilabs -p <token>
OVSX_TOKEN=
